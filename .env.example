# S3-compatible object storage (AWS S3, RustFS, MinIO, …).
# For a local RustFS instance the defaults below usually work as-is.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=excalidraw
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin

# Comma-separated origins allowed to POST new drawings.
ALLOW_ORIGINS=https://excalidraw.com,http://localhost:3000

# HTTP port to listen on (optional, defaults to 8080).
PORT=8080
